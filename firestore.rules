rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // A user can read and write only their own profile + all sub-collections under it.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
