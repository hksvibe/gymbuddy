# Copy to .env.local once your Firebase project is created.
# Get these from Firebase Console → Project Settings → General → Your apps → Web app.
# Until these are set, the app runs against localStorage + a built-in mock planner
# (so the demo flow works without any backend).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=gymbuddy-prod
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ----- Cloud Functions secrets (do NOT put these in .env.local) -----
# Set with:
#   firebase functions:secrets:set GROQ_API_KEY
#   firebase functions:secrets:set YOUTUBE_API_KEY
#
# GROQ_API_KEY    — used by generatePlan (llama-3.3-70b-versatile) and
#                   detectEquipment (llama-4-scout-17b-16e vision). Free tier
#                   at https://console.groq.com/keys is enough for a demo.
# YOUTUBE_API_KEY — used by resolveVideo (YouTube Data API v3). Optional;
#                   if missing, the app falls back to a YouTube-search link.
